<%
  let firstChapterPageUrl = "";
  if (Array.isArray(pageUrls) && pageUrls.length > 0) {
    firstChapterPageUrl = (pageUrls[0] || "").toString().trim();
  }

  let chapterPageOrigin = "";
  if (firstChapterPageUrl) {
    try {
      chapterPageOrigin = new URL(firstChapterPageUrl).origin;
    } catch (_err) {
      chapterPageOrigin = "";
    }
  }

  const chapterHeadScripts = {
    filters: false,
    admin: false,
    comments: true,
    lazysizes: false,
    readingHistory: true
  };
%>
<!DOCTYPE html>
<html lang="vi">
  <%- include("partials/head", {
    title,
    headScripts: chapterHeadScripts,
    headPreconnectOrigins: chapterPageOrigin ? [chapterPageOrigin] : []
  }) %>
  <body class="reader-page">
    <div class="site">
      <%- include("partials/header") %>
      <main
        data-reading-progress
        data-reading-manga-slug="<%= manga.slug %>"
        data-reading-chapter-number="<%= chapter.number %>"
      >
        <section class="section container">
          <div class="reader-header">
            <div class="reader-title">
              <a class="reader-back" href="/manga/<%= manga.slug %>">Quay lại truyện</a>
              <% const chapterTitle = (chapter.title || "").toString().trim(); %>
              <% const isOneshotChapter = Boolean(chapter && chapter.is_oneshot); %>
              <% const chapterHeadingLabel = isOneshotChapter ? "Oneshot" : `Chương ${chapter.number}`; %>
              <% const chapterShortLabel = isOneshotChapter ? "Oneshot" : `Ch. ${chapter.number}`; %>
              <% const buildChapterOptionLabel = (item) => {
                const chapterItem = item && typeof item === "object" ? item : {};
                const itemTitle = (chapterItem.title || "").toString().trim();
                const baseLabel = chapterItem.is_oneshot ? "Oneshot" : `Ch. ${chapterItem.number}`;
                return itemTitle ? `${baseLabel} — ${itemTitle}` : baseLabel;
              }; %>
              <h1><%= chapterHeadingLabel %><% if (chapterTitle) { %>: <%= chapterTitle %><% } %></h1>
              <div class="reader-meta">
                <span><%= manga.title %></span>
                <span class="reader-dot">•</span>
                <span><%= chapter.pages %> trang</span>
                <span class="reader-dot">•</span>
                <span>Cập nhật <%= formatDate(chapter.date) %></span>
              </div>
            </div>
          </div>
          <% const processingState = (chapter.processing_state || "").toString().trim(); %>
          <% if (processingState === "processing") { %>
            <p class="reader-note">Chương đang xử lý ảnh, vui lòng quay lại sau.</p>
          <% } else if (!pageUrls || pageUrls.length === 0) { %>
            <p class="reader-note">Trang đọc mẫu: hiển thị khung trang, chưa có ảnh scan.</p>
          <% } %>
        </section>

        <section class="section container reader">
          <div class="reader-fixed reader-fixed--top" data-reader-fixed>
            <div class="reader-fixed-inner">
              <%- include("partials/chapter-reader-controls", {
                manga,
                chapter,
                chapterTitle,
                chapterShortLabel,
                chapterList,
                prevChapter,
                nextChapter,
                buildChapterOptionLabel,
                dropdownClass: "reader-dropdown--down"
              }) %>
            </div>
          </div>
          <% const lazyPlaceholderSrc = "data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///ywAAAAAAQABAAACAUwAOw=="; %>
          <% const readerNextPrefetchPayload = encodeURIComponent(
            JSON.stringify(Array.isArray(nextChapterPrefetchUrls) ? nextChapterPrefetchUrls : [])
          ); %>
          <% const totalChapterPages = Math.max(Number(chapter && chapter.pages ? chapter.pages : 0) || 0, 0); %>
          <% const chapterViewThreshold = Math.max(1, Math.floor(totalChapterPages / 2 + 1)); %>
          <div
            class="reader-pages"
            data-reader-lazy-pages
            data-reader-next-prefetch="<%= readerNextPrefetchPayload %>"
            data-reader-view-track-url="/manga/<%= encodeURIComponent(manga.slug) %>/chapters/<%= encodeURIComponent(String(chapter.number)) %>/view"
            data-reader-view-track-token="<%= chapterViewTrackToken %>"
            data-reader-view-threshold="<%= chapterViewThreshold %>"
            data-reader-total-pages="<%= totalChapterPages %>"
          >
            <% if (pageUrls && pageUrls.length) { %>
              <% const eagerPageCount = Math.min(3, pageUrls.length); %>
              <% pageUrls.forEach((src, index) => { %>
                <% const isEagerPage = index < eagerPageCount; %>
                <div class="page-card">
                  <div class="page-frame">
                    <img
                      class="page-media page-media--lazy <%= isEagerPage ? "is-loaded" : "is-placeholder lazyload" %>"
                      src="<%= isEagerPage ? src : lazyPlaceholderSrc %>"
                      <% if (!isEagerPage) { %>data-src="<%= src %>"<% } %>
                      data-page-index="<%= index %>"
                      alt="Trang <%= index + 1 %>"
                      loading="<%= isEagerPage ? "eager" : "lazy" %>"
                      decoding="async"
                      fetchpriority="<%= index === 0 ? "high" : isEagerPage ? "auto" : "low" %>"
                    />
                  </div>
                </div>
              <% }) %>
            <% } else if (pages.length === 0) { %>
              <p class="note">Chưa có trang nào cho chương này.</p>
            <% } else { %>
              <% pages.forEach((page) => { %>
                <div class="page-card">
                  <div class="page-paper">
                    <span class="page-number">Trang <%= page %></span>
                  </div>
                </div>
              <% }) %>
            <% } %>
          </div>

          <% if (pageUrls && pageUrls.length) { %>
            <noscript>
              <style>
                [data-reader-lazy-pages] {
                  display: none !important;
                }
              </style>
              <div class="reader-pages">
                <% pageUrls.forEach((src, index) => { %>
                  <div class="page-card">
                    <div class="page-frame">
                      <img
                        class="page-media"
                        src="<%= src %>"
                        alt="Trang <%= index + 1 %>"
                        loading="lazy"
                      />
                    </div>
                  </div>
                <% }) %>
              </div>
            </noscript>
          <% } %>
          <div class="reader-fixed reader-fixed--bottom" data-reader-fixed>
            <div class="reader-fixed-inner">
              <%- include("partials/chapter-reader-controls", {
                manga,
                chapter,
                chapterTitle,
                chapterShortLabel,
                chapterList,
                prevChapter,
                nextChapter,
                buildChapterOptionLabel,
                dropdownClass: ""
              }) %>
            </div>
          </div>
        </section>

        <% const chapterCommentBasePath = `/manga/${manga.slug}/chapters/${encodeURIComponent(String(chapter.number))}`; %>
        <%- include("partials/manga-comments-section", {
          manga,
          comments,
          commentCount,
          commentPagination,
          commentComposerEnabled,
          commentScope: "chapter",
          commentBasePathOverride: chapterCommentBasePath
        }) %>
      </main>
      <div class="reader-float" data-reader-float>
        <div class="reader-float-inner">
          <%- include("partials/chapter-reader-controls", {
            manga,
            chapter,
            chapterTitle,
            chapterShortLabel,
            chapterList,
            prevChapter,
            nextChapter,
            buildChapterOptionLabel,
            dropdownClass: ""
          }) %>
        </div>
      </div>
      <div class="reader-quick" data-reader-quick>
        <button class="reader-quick-btn" type="button" data-reader-top aria-label="Lên đầu trang">
          <svg class="reader-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M6 15l6-6 6 6" />
          </svg>
        </button>
        <button
          class="reader-quick-btn"
          type="button"
          data-reader-comments
          aria-label="Xuống bình luận"
        >
          <svg class="reader-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M6 9l6 6 6-6" />
          </svg>
        </button>
      </div>
      <%- include("partials/comments-lazy-loader") %>
      <%- include("partials/footer") %>
    </div>
  </body>
</html>
